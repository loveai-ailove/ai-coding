generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Status {
  ACTIVE
  DISABLED
}

enum MenuType {
  DIRECTORY
  MENU
  BUTTON
}

enum DataScopeType {
  SELF
  DEPT
  DEPT_AND_CHILD
  ALL
}

model SysDept {
  id        Int       @id @default(autoincrement())
  parentId  Int?      @map("parent_id")
  ancestors String    @default("0")
  name      String
  orderNum  Int       @default(0) @map("order_num")
  leader    String?
  phone     String?   @db.VarChar(20)
  email     String?
  status    Status    @default(ACTIVE)
  remark    String?   @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  parent    SysDept?  @relation("SysDeptTree", fields: [parentId], references: [id], onDelete: Restrict)
  children  SysDept[] @relation("SysDeptTree")
  users     SysUser[]

  @@index([parentId])
  @@map("sys_dept")
}

model SysRole {
  id        Int           @id @default(autoincrement())
  name      String
  code      String        @unique
  orderNum  Int           @default(0) @map("order_num")
  dataScope DataScopeType @default(DEPT_AND_CHILD) @map("data_scope")
  status    Status        @default(ACTIVE)
  remark    String?       @db.Text
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  users     SysUserRole[]
  menus     SysRoleMenu[]

  @@map("sys_role")
}

model SysMenu {
  id        Int         @id @default(autoincrement())
  parentId  Int?        @map("parent_id")
  name      String
  type      MenuType
  path      String?
  component String?
  perms     String?
  icon      String?
  orderNum  Int         @default(0) @map("order_num")
  visible   Boolean     @default(true)
  status    Status      @default(ACTIVE)
  remark    String?     @db.Text
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  parent    SysMenu?    @relation("SysMenuTree", fields: [parentId], references: [id], onDelete: Restrict)
  children  SysMenu[]   @relation("SysMenuTree")
  roles     SysRoleMenu[]

  @@index([parentId])
  @@map("sys_menu")
}

model SysUser {
  id          Int              @id @default(autoincrement())
  username    String           @unique
  nickname    String
  passwordHash String          @map("password_hash")
  email       String?          @unique
  mobile      String?          @unique @db.VarChar(20)
  deptId      Int?             @map("dept_id")
  status      Status           @default(ACTIVE)
  isAdmin     Boolean          @default(false) @map("is_admin")
  lastLoginAt DateTime?        @map("last_login_at")
  lastLoginIp String?          @map("last_login_ip")
  remark      String?          @db.Text
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  dept        SysDept?         @relation(fields: [deptId], references: [id], onDelete: SetNull)
  roles       SysUserRole[]
  sessions    SysUserSession[]
  operLogs    SysOperLog[]
  loginLogs   SysLoginLog[]

  @@index([deptId])
  @@map("sys_user")
}

model SysUserRole {
  userId Int
  roleId Int
  user   SysUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   SysRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("sys_user_role")
}

model SysRoleMenu {
  roleId Int
  menuId Int
  role   SysRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menu   SysMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@id([roleId, menuId])
  @@index([menuId])
  @@map("sys_role_menu")
}

model SysUserSession {
  id           String   @id @default(cuid())
  userId       Int      @map("user_id")
  token        String   @unique
  expiresAt    DateTime @map("expires_at")
  lastAccessAt DateTime @default(now()) @map("last_access_at")
  ip           String?
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")
  user         SysUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sys_user_session")
}

enum OperType {
  CREATE
  UPDATE
  DELETE
  QUERY
  IMPORT
  EXPORT
  LOGIN
  LOGOUT
  OTHER
}

enum LoginStatus {
  SUCCESS
  FAIL
}

enum AiModelType {
  LLM
  EMBEDDING
}

model SysOperLog {
  id            Int       @id @default(autoincrement())
  userId        Int?      @map("user_id")
  username      String?
  module        String    @db.VarChar(50)
  operType      OperType  @map("oper_type")
  description   String?   @db.VarChar(500)
  method        String?   @db.VarChar(10)
  requestUrl    String?   @map("request_url")
  requestParam  String?   @map("request_param") @db.Text
  response      String?   @db.Text
  ip            String?   @db.VarChar(50)
  status        Status    @default(ACTIVE)
  errorMsg      String?   @map("error_msg") @db.Text
  operTime      DateTime  @default(now()) @map("oper_time")
  costTime      Int?      @map("cost_time")
  user          SysUser?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([operTime])
  @@index([module])
  @@map("sys_oper_log")
}

model SysLoginLog {
  id          Int         @id @default(autoincrement())
  userId      Int?        @map("user_id")
  sessionToken String?    @unique @map("session_token")
  username    String?     @db.VarChar(50)
  ip          String?     @db.VarChar(50)
  userAgent   String?     @map("user_agent")
  status      LoginStatus @default(SUCCESS)
  loginTime   DateTime    @default(now()) @map("login_time")
  logoutTime  DateTime?   @map("logout_time")
  msg         String?     @db.VarChar(500)
  user        SysUser?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([loginTime])
  @@index([username])
  @@map("sys_login_log")
}

model AiModel {
  id                  Int         @id @default(autoincrement())
  type                AiModelType
  name                String
  code                String      @unique
  provider            String
  protocol            String      @default("openai-compatible")
  model               String
  baseUrl             String      @map("base_url")
  apiKey              String      @map("api_key") @db.Text
  isActive            Boolean     @default(true) @map("is_active")
  isDefault           Boolean     @default(false) @map("is_default")
  sort                Int         @default(0)
  maxContext          Int?        @map("max_context")
  maxResponse         Int?        @map("max_response")
  quoteMaxToken       Int?        @map("quote_max_token")
  maxTemperature      Float?      @map("max_temperature")
  defaultSystemPrompt String?     @map("default_system_prompt") @db.Text
  embeddingDimension  Int?        @map("embedding_dimension")
  embeddingMaxToken   Int?        @map("embedding_max_token")
  defaultConfig       Json?       @map("default_config")
  remark              String?     @db.Text
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  @@index([type, isActive, sort])
  @@index([type, isDefault])
  @@map("ai_model")
}
